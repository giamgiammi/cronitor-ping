[Unit]
Description=Ping cronitor service at the specified url
After=network.target network-online.target
Requisite=network.target network-online.target

[Service]
ExecStart=%PREFIX/sbin/cronitor-ping
LoadCredential=cronitor.url:/etc/cronitor.url
RuntimeDirectory=cronitor-ping
RuntimeDirectoryPreserve=yes
Type=simple
DynamicUser=yes
Restart=no